@model EduGate.ViewModels.Teacher.DashboardVM
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Dashboard - EduGate</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="app-layout">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                    EduGate
                </a>
            </div>
            <div class="sidebar-user">
                <div class="user-avatar">@Model.Initials</div>
                <div class="user-info">
                    <div class="user-name">@Model.TeacherName</div>
                    <div class="user-role">Teacher</div>
                </div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Main</div>
                    <a asp-controller="Teacher" asp-action="Dashboard" class="nav-item active">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                        Dashboard
                    </a>
                    <a asp-controller="Teacher" asp-action="Students" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>
                        Students
                    </a>
                    <a asp-controller="Teacher" asp-action="Courses" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>
                        Courses
                    </a>
                    <a asp-controller="Teacher" asp-action="Exams" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                        Exams
                    </a>
                </div>
                <div class="nav-section">
                    <div class="nav-section-title">Account</div>
                    <a asp-controller="Teacher" asp-action="Upgrade" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>
                        Upgrade Plan
                    </a>
                    <a asp-controller="Teacher" asp-action="Settings" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" /></svg>
                        Settings
                    </a>
                </div>
            </nav>
            <div class="sidebar-footer">
                <a asp-controller="Auth" asp-action="Login" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="topbar">
                <h1 class="topbar-title">Dashboard</h1>
                <div class="topbar-actions">
                    <button class="icon-btn" onclick="showToast('No new notifications', 'info')">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 01-3.46 0" /></svg>
                        <span style="position:absolute;top:4px;right:4px;width:8px;height:8px;background:var(--primary);border-radius:50%;"></span>
                    </button>
                </div>
            </div>

            <div class="page-content">
                <!-- Stats Grid -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-header">
                            <span class="stat-label">Total Students</span>
                            <div class="stat-icon blue">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                            </div>
                        </div>
                        <div class="stat-value">@Model.TotalStudents</div>
                        @* <div class="stat-change up">+12 this month</div> *@
                    </div>
                    <div class="stat-card">
                        <div class="stat-header">
                            <span class="stat-label">Active Courses</span>
                            <div class="stat-icon green">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>
                            </div>
                        </div>
                        <div class="stat-value">@Model.ActiveCourses</div>
                        @* <div class="stat-change up">+2 new</div> *@
                    </div>
                    <div class="stat-card">
                        <div class="stat-header">
                            <span class="stat-label">Upcoming Exams</span>
                            <div class="stat-icon purple">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                            </div>
                        </div>
                        <div class="stat-value">@Model.UpcomingExams</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-header">
                            <span class="stat-label">Remaining Seats</span>
                            <div class="stat-icon" style="background: rgba(249, 115, 22, 0.1); color: #F97316;">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="23" y1="11" x2="17" y2="11" /></svg>
                            </div>
                        </div>
                        <div class="stat-value">@Model.RemainingSeats</div>
                    </div>
                </div>

                <!-- Dashboard Grid -->
                <div class="dashboard-grid">
                    
                    <!-- Left Column (wider) -->
                    <div>
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Recent Courses</h3>
                            </div>
                            <div style="display:flex;flex-direction:column;gap:16px;">
                                @if (Model.RecentCourses != null && Model.RecentCourses.Any())
                                {
                                    foreach (var course in Model.RecentCourses)
                                    {
                                        <div style="padding-bottom: 10px; border-bottom: 1px solid #eee;">
                                            <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                                                <span style="font-size:14px; font-weight:600;">@course.Name</span>
                                                <span style="font-size:12px;color:var(--text-muted);">
                                                    @course.CreatedAt.ToString("MMM dd, yyyy")
                                                </span>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div style="font-size:13px;color:var(--text-muted);text-align:center;">
                                        No courses added yet.
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Right Column (narrower) -->
                    <div>
                        <div class="card" style="margin-bottom: 24px;">
                            <div class="card-header">
                                <h3 class="card-title">Quick Actions</h3>
                            </div>
                            <div style="display:flex;flex-direction:column;gap:10px;">
                                <a asp-controller="Teacher" asp-action="Generate_Students" class="btn btn-outline" style="justify-content:flex-start;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="8.5" cy="7" r="4" /><line x1="20" y1="8" x2="20" y2="14" /><line x1="23" y1="11" x2="17" y2="11" /></svg>
                                    Generate Student Accounts
                                </a>
                                <a asp-controller="Teacher" asp-action="Add_Course" class="btn btn-outline" style="justify-content:flex-start;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>
                                    Create New Course
                                </a>
                                <a asp-controller="Teacher" asp-action="Add_Exam" class="btn btn-outline" style="justify-content:flex-start;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                                    Create Exam
                                </a>
                            </div>
                        </div>

                    </div>
                </div>


            </div>
        </main>
    </div>

    <script src="~/js/app.js"></script>
</body>