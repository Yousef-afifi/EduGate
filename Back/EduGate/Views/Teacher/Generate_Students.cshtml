@model EduGate.ViewModels.Teacher.GenerateStudentsVM
@using EduGate.Enums
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Generate Students - EduGate</title>
  <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
  <div class="app-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <a asp-controller="Home" asp-action="Index" class="logo">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          EduGate
        </a>
      </div>
      <div class="sidebar-user">
        <div class="user-avatar">@Model.Initials</div>
        <div class="user-info"><div class="user-name">@Model.TeacherName</div><div class="user-role">Teacher</div></div>
      </div>
      <nav class="sidebar-nav">
        <div class="nav-section"><div class="nav-section-title">Main</div>
          <a asp-controller="Teacher" asp-action="Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>Dashboard</a>
          <a asp-controller="Teacher" asp-action="Students" class="nav-item active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>Students</a>
          <a asp-controller="Teacher" asp-action="Courses" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>Courses</a>
          <a asp-controller="Teacher" asp-action="Exams" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>Exams</a>
        </div>
        <div class="nav-section"><div class="nav-section-title">Account</div>
          <a asp-controller="Teacher" asp-action="Upgrade" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>Upgrade Plan</a>
          <a asp-controller="Teacher" asp-action="Settings" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" /></svg>Settings</a>
        </div>
      </nav>
      <div class="sidebar-footer">
          <a asp-controller="Auth" asp-action="Login" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Logout</a>
      </div>
    </aside>

    <main class="main-content">
      <div class="topbar">
        <div style="display:flex;align-items:center;gap:12px;">
          <a asp-controller="Teacher" asp-action="Students" class="icon-btn"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" /></svg></a>
          <h1 class="topbar-title">Generate Student Accounts</h1>
        </div>
      </div>

      <div class="page-content">
        <div style="max-width:600px;">
          <form asp-action="Generate_Students" method='post'>
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <input asp-for="TeacherName" type="hidden" />
                        <input asp-for="Initials" type="hidden" />
                        <div class="card" style="margin-bottom:24px;">
                            <div class="form-group">
                                <label asp-for="NumberOfStudents" class="form-label">Number of Students</label>
                                <input asp-for="NumberOfStudents" type="number" class="form-input" min="1" id="studentCount">
                                <p class="form-hint">You can generate up to @Model.MaxStudents students at once. Remaining: @Model.RemainingSlots slots.</p>
                                <span asp-validation-for="NumberOfStudents" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Assign to Course (Optional)</label>
                                <select asp-for="CourseId" asp-items="Model.Courses" class="form-select">
                                </select>
                            </div>
                            <div class="form-group">
                                <label asp-for="NamingType" class="form-label">Naming Convention</label>
                                <select asp-for="NamingType" class="form-select" id="namingConvention">
                                    <option value="@((int)NamingType.AutoGenerate)">Auto-generate emails</option>
                                    <option value="@((int)NamingType.FixedPrefix)">Custom prefix</option>
                                </select>
                            </div>
                            <div class="form-group" id="prefixGroup" style="display:none;">
                                <label asp-for="Prefix" class="form-label">Email Prefix</label>
                                <input asp-for="Prefix" type="text" class="form-input" placeholder="student">
                            </div>
                            <div class="form-group">
                                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                                    <input asp-for="SendWelcomeEmail" type="checkbox" style="accent-color:var(--primary);">
                                    <span style="font-size:14px;">Send welcome email with login credentials</span>
                                </label>
                            </div>
                            <button type="submit" class="btn btn-primary w-full" style="padding:12px;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                                Generate Accounts
                            </button>
                        </div>
          </form>

          @if(Model.GeneratedStudents.Any())
          {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Generated Accounts</h3>
                                <button class="btn btn-sm btn-outline" onclick="copyAllCredentials()">Copy All</button>
                            </div>
                            <div class="table-wrap">
                                <table class="data-table">
                                    <thead><tr><th>Email</th><th>Password</th><th></th></tr></thead>
                                    <tbody>
                                        @foreach(var item in Model.GeneratedStudents)
                                        {
                                            <tr>
                                                <td>@item.Email</td>
                                                <td>@item.Password</td>
                                                <td><button type="button" class="btn btn-sm btn-outline" onclick="copyCredential('@item.Email','@item.Password')">Copy</button></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
          }
        </div>
      </div>
    </main>
  </div>
    <script>
            document.addEventListener("DOMContentLoaded", function () {

                const namingConvention = document.getElementById("namingConvention");
                const prefixGroup = document.getElementById("prefixGroup");

                function togglePrefix() {
                    prefixGroup.style.display =
                        namingConvention.value == "2" ? "block" : "none";
                }

                togglePrefix();

                namingConvention.addEventListener("change", togglePrefix);

            });

            function copyCredential(email, password) {

                navigator.clipboard.writeText(email + " / " + password);

                showToast("Credentials copied successfully!", "success");
            }

            function copyAllCredentials() {

                let text = "Student Accounts\n====================\n\n";

                const rows = document.querySelectorAll(".data-table tbody tr");

                rows.forEach(row => {

                    const email = row.cells[0].innerText;
                    const password = row.cells[1].innerText;

                    text += `${email} / ${password}\n`;

                });

                navigator.clipboard.writeText(text);

                showToast("All credentials copied successfully!", "success");
            }
    </script>
  <script src="~/js/app.js"></script>
</body>