<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Course - EduGate</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar">
            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                    EduGate
                </a>
            </div>
            <div class="sidebar-user">
                <div class="user-avatar">JD</div>
                <div class="user-info"><div class="user-name">John Doe</div><div class="user-role">Teacher</div></div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Main</div>
                    <a asp-controller="Teacher" asp-action="Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>Dashboard</a>
                    <a asp-controller="Teacher" asp-action="Students" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>Students</a>
                    <a asp-controller="Teacher" asp-action="Courses" class="nav-item active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>Courses</a>
                    <a asp-controller="Teacher" asp-action="Exams" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>Exams</a>
                </div>
                <div class="nav-section">
                    <div class="nav-section-title">Account</div>
                    <a asp-controller="Teacher" asp-action="Upgrade" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>Upgrade Plan</a>
                    <a asp-controller="Teacher" asp-action="Settings" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" /></svg>Settings</a>
                </div>
            </nav>
            <div class="sidebar-footer">
                <a asp-controller="Auth" asp-action="Login" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Logout</a>
            </div>
        </aside>

        <main class="main-content">
            <div class="topbar">
                <div style="display:flex;align-items:center;gap:12px;">
                    <a asp-controller="Teacher" asp-action="Courses" class="icon-btn"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" /></svg></a>
                    <h1 class="topbar-title">Add Course</h1>
                </div>
            </div>

            <div class="page-content">
                <div style="max-width:700px;">
                    <div class="card">
                        <div class="form-group">
                            <label class="form-label">Course Name</label>
                            <input type="text" class="form-input" placeholder="e.g., Advanced Calculus" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Description</label>
                            <textarea class="form-textarea" placeholder="Describe what students will learn..."></textarea>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Color Theme</label>
                            <select class="form-select">
                                <option value="red">Red</option>
                                <option value="blue">Blue</option>
                                <option value="green">Green</option>
                                <option value="purple">Purple</option>
                                <option value="orange">Orange</option>
                                <option value="teal">Teal</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Course Image (Optional)</label>
                            <input type="file" id="courseImageInput" accept="image/png,image/jpeg" style="display:none;">
                            <div id="courseImageDropzone" style="border:2px dashed var(--border);border-radius:var(--radius);padding:32px;text-align:center;cursor:pointer;transition:var(--transition);">
                                <img id="courseImagePreview" alt="Course image preview" style="display:none;width:100%;max-height:220px;object-fit:cover;border-radius:var(--radius);margin-bottom:12px;">
                                <svg id="courseImageIcon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--text-muted);margin:0 auto 12px;"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" /></svg>
                                <p id="courseImageText" style="font-size:14px;color:var(--text-muted);">Click to upload or drag and drop</p>
                                <p id="courseImageHint" style="font-size:12px;color:var(--text-muted);">PNG, JPG up to 5MB</p>
                            </div>
                        </div>
                        <div style="display:flex;gap:12px;justify-content:flex-end;">
                            <a asp-controller="Teacher" asp-action="Courses" class="btn btn-outline">Cancel</a>
                            <button class="btn btn-primary" onclick="showToast('Course created successfully!', 'success'); setTimeout(()=>window.location.href='../courses.html', 800);">Create Course</button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
    <script src="~/js/app.js"></script>
    <script>
        const courseImageInput = document.getElementById('courseImageInput');
        const courseImageDropzone = document.getElementById('courseImageDropzone');
        const courseImagePreview = document.getElementById('courseImagePreview');
        const courseImageIcon = document.getElementById('courseImageIcon');
        const courseImageText = document.getElementById('courseImageText');
        const courseImageHint = document.getElementById('courseImageHint');

        function handleCourseImage(file) {
        if (!file || !file.type.startsWith('image/')) {
        showToast('Please upload a PNG or JPG image', 'error');
        return;
        }

        courseImagePreview.src = URL.createObjectURL(file);
        courseImagePreview.style.display = 'block';
        courseImageIcon.style.display = 'none';
        courseImageText.textContent = file.name;
        courseImageHint.textContent = 'Image selected';
        }

        courseImageDropzone.addEventListener('click', () => courseImageInput.click());
        courseImageDropzone.addEventListener('dragover', (event) => {
        event.preventDefault();
        courseImageDropzone.style.borderColor = 'var(--primary)';
        });
        courseImageDropzone.addEventListener('dragleave', () => {
        courseImageDropzone.style.borderColor = 'var(--border)';
        });
        courseImageDropzone.addEventListener('drop', (event) => {
        event.preventDefault();
        courseImageDropzone.style.borderColor = 'var(--border)';
        courseImageInput.files = event.dataTransfer.files;
        handleCourseImage(event.dataTransfer.files[0]);
        });
        courseImageInput.addEventListener('change', () => {
        handleCourseImage(courseImageInput.files[0]);
        });
    </script>
</body>