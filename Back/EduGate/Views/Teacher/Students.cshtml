<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        Students - EduPlatform
    </title>
    <link rel="stylesheet" href="../../css/teacher-dashboard.css" />
</head>
<body data-user-name="@Model?.CurrentUserName" data-user-role="Teacher">
    @*
    Required ViewModel Data:
    * Teacher Students
    * Student Assigned Courses
    * Student Progress
    * Student Status
    *@
    <div id="sidebar-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:99">
    </div>
    <div class="app-shell">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar__logo">
                <div class="sidebar__logo-mark">
                    &#127891;
                </div>
                <span class="sidebar__logo-name">
                    EduPlatform
                </span>
            </div>
            <div class="sidebar__user">
                <div class="sidebar__avatar" id="sidebar-avatar">
                    U
                </div>
                <div>
                    <div class="sidebar__user-name" id="sidebar-user-name">
                        @Model?.CurrentUserName
                    </div>
                    <div class="sidebar__user-role" id="sidebar-user-role">
                        Teacher
                    </div>
                </div>
            </div>
            <nav class="sidebar__nav" id="sidebar-nav">
                <div class="sidebar__nav-section">
                    Workspace
                </div>
                <a asp-controller="Teacher" asp-action="Dashboard" class="nav-item">
                    <span class="nav-icon">
                        &#127968;
                    </span>
                    <span>
                        Dashboard
                    </span>
                </a>
                <a asp-controller="Teacher" asp-action="Courses" class="nav-item">
                    <span class="nav-icon">
                        &#128218;
                    </span>
                    <span>
                        Courses
                    </span>
                </a>
                <a asp-controller="Teacher" asp-action="Exams" class="nav-item">
                    <span class="nav-icon">
                        &#128221;
                    </span>
                    <span>
                        Exams
                    </span>
                </a>
                <a asp-controller="Teacher" asp-action="Students" class="nav-item">
                    <span class="nav-icon">
                        &#128101;
                    </span>
                    <span>
                        Students
                    </span>
                </a>
                <a asp-controller="Teacher" asp-action="Upgrade" class="nav-item">
                    <span class="nav-icon">
                        &#11014;
                    </span>
                    <span>
                        Upgrade
                    </span>
                </a>
                <a asp-controller="Teacher" asp-action="Settings" class="nav-item">
                    <span class="nav-icon">
                        &#9881;
                    </span>
                    <span>
                        Settings
                    </span>
                </a>
            </nav>
            <div class="sidebar__bottom">
                <button class="sidebar__logout" id="logout-btn">
                    <span class="nav-icon">
                        &#128682;
                    </span>
                    Sign Out
                </button>
            </div>
        </aside>
        <div class="main-content">
            <header class="topbar">
                <div class="topbar__left">
                    <button class="menu-toggle" id="menu-toggle">
                        &#9776;
                    </button>
                    <button class="sidebar-peek-toggle" id="sidebar-peek-toggle" title="Toggle sidebar">
                        &#9776;
                    </button>
                    <div>
                        <div class="topbar__title" id="page-title">
                            Students
                        </div>
                        <div class="topbar__breadcrumb" id="page-breadcrumb">
                        </div>
                    </div>
                </div>
                <div class="topbar__right">
                    <div class="topbar-search">
                        <span class="search-icon">
                            &#128269;
                        </span>
                        <input type="text" placeholder="Search students..." id="global-search" />
                    </div>
                    <div style="font-size:13px;font-weight:600;color:var(--navy)" id="topbar-user-name">
                        @Model?.CurrentUserName
                    </div>
                </div>
            </header>
            <main class="page-body dashboard-view-ready" id="dashboard-content">
                <div class="section-header">
                    <div>
                        <div class="section-title">Student Account Management</div>
                        <div style="font-size:13px;color:var(--gray-400);margin-top:6px">Track the students using your package seats and their learning activity.</div>
                    </div>
                    <button class="btn-amber" onclick="openTeacherGenerateAccounts()">Generate Accounts</button>
                </div>
                <div class="stats-row">
                    <div class="stat-card"><div class="stat-card__icon">👥</div><div class="stat-card__num">0</div><div class="stat-card__label">Visible Students</div></div>
                    <div class="stat-card"><div class="stat-card__icon">🔒</div><div class="stat-card__num">600</div><div class="stat-card__label">Package Capacity</div></div>
                    <div class="stat-card"><div class="stat-card__icon">✅</div><div class="stat-card__num">0</div><div class="stat-card__label">Active Students</div></div>
                    <div class="stat-card"><div class="stat-card__icon">📈</div><div class="stat-card__num">NaN%</div><div class="stat-card__label">Average Progress</div></div>
                </div>
                <div class="table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr><th>Student</th><th>Course</th><th>Progress</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </main>
        </div>
    </div>
    <script src="../../js/app.js">
    </script>
</body>