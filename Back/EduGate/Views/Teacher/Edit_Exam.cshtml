@model EduGate.ViewModels.Teacher.EditExamVM
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Exam - Calculus II Midterm - EduGate</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar">
            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                    EduGate
                </a>
            </div>
            <div class="sidebar-user">
                <div class="user-avatar">@Model.Initials</div>
                <div class="user-info"><div class="user-name">@Model.TeacherName</div><div class="user-role">Teacher</div></div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Main</div>
                    <a asp-controller="Teacher" asp-action="Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>Dashboard</a>
                    <a asp-controller="Teacher" asp-action="Students" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>Students</a>
                    <a asp-controller="Teacher" asp-action="Courses" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>Courses</a>
                    <a asp-controller="Teacher" asp-action="Exams" class="nav-item active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>Exams</a>
                </div>
                <div class="nav-section">
                    <div class="nav-section-title">Account</div>
                    <a asp-controller="Teacher" asp-action="Upgrade" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>Upgrade Plan</a>
                    <a asp-controller="Teacher" asp-action="Settings" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" /></svg>Settings</a>
                </div>
            </nav>
            <div class="sidebar-footer">
                <a asp-controller="Auth" asp-action="Login" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Logout</a>
            </div>
        </aside>

        <main class="main-content">
            <div class="topbar">
                <div style="display:flex;align-items:center;gap:12px;">
                    <a asp-controller="Teacher" asp-action="Exams" class="icon-btn"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" /></svg></a>
                    <h1 class="topbar-title">Edit Exam</h1>
                </div>
            </div>

            <div class="page-content">
                <div style="max-width:700px;">
                    <form asp-action="Edit_Exam" method="post">
                        <input asp-for="CourseId" type="hidden" />
                        <input asp-for="ExamId" type="hidden" />
                        <div class="card" style="margin-bottom:24px;">

                            <div class="form-group">
                                <label asp-for="ExamTitle" class="form-label">Exam Title</label>
                                <input asp-for="ExamTitle" type="text" class="form-input" placeholder="e.g., Calculus II - Final Examination" required>
                            </div>

                            <div style="padding:12px 16px;background:var(--primary-light);border-radius:var(--radius);margin-bottom:20px;">
                                <span style="font-size:13px;color:var(--primary);font-weight:500;">Course: @Model.CourseName</span>
                            </div>

                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                                <div class="form-group">
                                    <label asp-for="Date" class="form-label">Date</label>
                                    <input asp-for="Date" type="date" class="form-input">
                                </div>
                                <div class="form-group">
                                    <label asp-for="Time" class="form-label">Start Time</label>
                                    <input asp-for="Time" type="time" class="form-input">
                                </div>
                            </div>
                            <div class="form-group">
                                <label asp-for="Duration" class="form-label">Duration (minutes)</label>
                                <input asp-for="Duration" type="number" class="form-input" placeholder="120" min="1">
                            </div>
                            
                                <div class="form-group">
                                    <label asp-for="PassingScore" class="form-label">Passing Score (%)</label>
                                    <input asp-for="PassingScore" type="number" class="form-input" placeholder="60" min="0" max="100">
                                </div>
                                
                            
                        </div>

                   
                            <h3 style="font-size:16px;font-weight:600;margin-bottom:16px;">Exam Questions</h3>
                            
                                <div id="examQuestions">
                                    @for (int i = 0; i < Model.Questions.Count; i++)
                                    {
                                        <div class="card" style="margin-bottom:16px;">
                                            <div class="form-group">
                                                <label class="form-label">Question @(i + 1)</label>
                                                <input type="text" class="form-input" name="Questions[@i].Text" value="@Model.Questions[i].Text">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Options</label>
                                                @for (int j = 0; j < Model.Questions[i].Choices.Count; j++)
                                                {
                                                    <div class="quiz-option">
                                                        <div class="quiz-option-letter">@((char)('A' + j))</div>
                                                        <input type="text" class="quiz-option-input" name="Questions[@i].Choices[@j].Text" value="@Model.Questions[i].Choices[j].Text">
                                                        <input type="hidden" name="Questions[@i].Choices[@j].IsCorrect" value="@Model.Questions[i].Choices[j].IsCorrect.ToString().ToLower()">
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            

                                <button type="button" class="btn btn-outline w-full" style="margin-bottom:24px;" onclick="addQuestion('examQuestions')">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                                    Add Question
                                </button>

                                <div style="display:flex;gap:12px;justify-content:flex-end;">
                                    <a asp-controller="Teacher" asp-action="Exams" class="btn btn-outline">Cancel</a>
                                    <button type="submit" class="btn btn-primary">Save Changes</button>
                            </div>
                        </form>

                </div>
            </div>
        </main>
    </div>
    <script src="~/js/app.js"></script>
</body>