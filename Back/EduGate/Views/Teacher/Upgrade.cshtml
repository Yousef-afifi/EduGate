@model EduGate.ViewModels.Teacher.UpgradeVM
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upgrade Plan - EduGate</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar">
            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                    EduGate
                </a>
            </div>
            <div class="sidebar-user">
                <div class="user-avatar">@Model.Initials</div>
                <div class="user-info"><div class="user-name">@Model.TeacherName</div><div class="user-role">Teacher</div></div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Main</div>
                    <a asp-controller="Teacher" asp-action="Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>Dashboard</a>
                    <a asp-controller="Teacher" asp-action="Students" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>Students</a>
                    <a asp-controller="Teacher" asp-action="Courses" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>Courses</a>
                    <a asp-controller="Teacher" asp-action="Exams" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>Exams</a>
                </div>
                <div class="nav-section">
                    <div class="nav-section-title">Account</div>
                    <a asp-controller="Teacher" asp-action="Upgrade" class="nav-item active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>Upgrade Plan</a>
                    <a asp-controller="Teacher" asp-action="Settings" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" /></svg>Settings</a>
                </div>
            </nav>
            <div class="sidebar-footer">
                <a asp-controller="Auth" asp-action="Login" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Logout</a>
            </div>
        </aside>

        <main class="main-content">
            <div class="topbar">
                <h1 class="topbar-title">Upgrade Plan</h1>
                <div class="topbar-actions">
                    <button class="icon-btn" onclick="showToast('No new notifications', 'info')"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 01-3.46 0" /></svg><span style="position:absolute;top:4px;right:4px;width:8px;height:8px;background:var(--primary);border-radius:50%;"></span></button>
                </div>
            </div>

            <div class="page-content">
                <div class="pricing-current">
                    <div class="pricing-current-info">Your current plan: <strong>Professional</strong> ($79.99/month) &middot; 352/600 students used</div>
                    <span class="badge badge-primary">Active</span>
                </div>

                <p class="section-label">Pricing</p>
                <h2 class="section-title" style="text-align:left;margin-bottom:8px;">Choose Your New Package</h2>
                <p class="section-desc" style="text-align:left;margin-bottom:32px;">Scale as your student base grows</p>

                <div class="pricing-grid" style="max-width:100%;">
                    <div class="pricing-card">
                        <h3 class="pricing-name">Starter</h3>
                        <div class="pricing-price">$29.99<span style="font-size:14px;color:var(--text-muted);font-weight:400;">/month</span></div>
                        <p class="pricing-limit">Up to 200 students</p>
                        <ul class="pricing-features">
                            <li><span class="feature-check">&#10003;</span> 200 Students</li>
                            <li><span class="feature-check">&#10003;</span> Unlimited Courses</li>
                            <li><span class="feature-check">&#10003;</span> Basic Analytics</li>
                            <li><span class="feature-check">&#10003;</span> Email Support</li>
                        </ul>
                        <button class="btn btn-outline w-full" onclick="showToast('Downgrade initiated', 'info')">Downgrade</button>
                    </div>
                    <div class="pricing-card popular">
                        <span class="popular-badge">CURRENT</span>
                        <h3 class="pricing-name">Professional</h3>
                        <div class="pricing-price">$79.99<span style="font-size:14px;opacity:0.7;font-weight:400;">/month</span></div>
                        <p class="pricing-limit">Up to 600 students</p>
                        <ul class="pricing-features">
                            <li><span class="feature-check">&#10003;</span> 600 Students</li>
                            <li><span class="feature-check">&#10003;</span> Unlimited Courses</li>
                            <li><span class="feature-check">&#10003;</span> Advanced Analytics</li>
                            <li><span class="feature-check">&#10003;</span> Priority Support</li>
                            <li><span class="feature-check">&#10003;</span> Custom Branding</li>
                        </ul>
                        <button class="btn btn-primary w-full" disabled>Current Plan</button>
                    </div>
                    <div class="pricing-card">
                        <h3 class="pricing-name">Enterprise</h3>
                        <div class="pricing-price">$149.99<span style="font-size:14px;color:var(--text-muted);font-weight:400;">/month</span></div>
                        <p class="pricing-limit">Up to 1000 students</p>
                        <ul class="pricing-features">
                            <li><span class="feature-check">&#10003;</span> 1000 Students</li>
                            <li><span class="feature-check">&#10003;</span> Unlimited Courses</li>
                            <li><span class="feature-check">&#10003;</span> Full Analytics</li>
                            <li><span class="feature-check">&#10003;</span> 24/7 Support</li>
                            <li><span class="feature-check">&#10003;</span> Custom Branding</li>
                            <li><span class="feature-check">&#10003;</span> API Access</li>
                        </ul>
                        <button class="btn btn-outline w-full" onclick="showToast('Upgrade to Enterprise initiated', 'success')">Upgrade</button>
                    </div>
                </div>
            </div>
        </main>
    </div>
    <script src="~/js/app.js"></script>
</body>