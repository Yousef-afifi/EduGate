@model EduGate.ViewModels.Student.CourseDetailsVM
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Name - EduGate</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar">
            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                    EduGate
                </a>
            </div>
            <div class="sidebar-user">
                <div class="user-avatar" style="background:#3B82F6;">@Model.initials</div>
                <div class="user-info"><div class="user-name">@Model.StudentName</div><div class="user-role">Student</div></div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Main</div>
                    <a asp-controller="Student" asp-action="Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>Dashboard</a>
                    <a asp-controller="Student" asp-action="Courses" class="nav-item active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>My Courses</a>
                    <a asp-controller="Student" asp-action="Exams" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>Exams</a>
                    <a asp-controller="Student" asp-action="Schedule" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>Schedule</a>
                </div>
                <div class="nav-section">
                    <div class="nav-section-title">Account</div>
                    <a asp-controller="Student" asp-action="Settings" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" /></svg>Settings</a>
                </div>
            </nav>
            <div class="sidebar-footer">
                <a asp-controller="Auth" asp-action="Login" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Logout</a>
            </div>
        </aside>

        <main class="main-content">
            <div class="topbar">
                <div style="display:flex;align-items:center;gap:12px;">
                    <a asp-controller="Student" asp-action="Courses" class="icon-btn"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" /></svg></a>
                    <h1 class="topbar-title">@Model.Name</h1>
                </div>
            </div>

            <div class="page-content">
                <div class="card" style="background:linear-gradient(135deg,#E84C4C,#FF8A80);color:white;margin-bottom:24px;">
                    <div style="display:flex;align-items:center;gap:20px;">
                        <div style="width:64px;height:64px;border-radius:var(--radius);background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:32px;">&#128218;</div>
                        <div style="flex:1;">
                            <h2 style="font-size:24px;font-weight:700;margin-bottom:4px;">@Model.Name</h2>
                            <p style="opacity:0.9;font-size:14px;">@Model.TeacherName &middot; @Model.Description</p>
                        </div>
                       
                    </div>
                </div>

                <div class="tabs">
                    <button class="tab active" onclick="switchTab(this,'lessons')">Lessons</button>
                    <button class="tab" onclick="switchTab(this,'quizzes')">Quizzes</button>
                    <button class="tab" onclick="switchTab(this,'assessments')">Assessments</button>
                    <button class="tab" onclick="switchTab(this,'materials')">Materials</button>
                </div>

                <div id="lessons" class="tab-content">
                    <div class="page-header">
                        <h3 style="font-size:18px;font-weight:600;">Lessons</h3>
                    </div>
                    <div class="card" style="margin-bottom:16px;">
                        <div class="student-video-player" style="aspect-ratio:16/9;border-radius:var(--radius);background:linear-gradient(135deg,#111827,#374151);color:white;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;">
                            <div style="width:64px;height:64px;border-radius:50%;background:rgba(255,255,255,0.16);display:flex;align-items:center;justify-content:center;font-size:28px;">&#9658;</div>
                            <div class="student-video-title" style="font-size:20px;font-weight:700;">@(Model.Lessons.FirstOrDefault()?.Name ?? "No Lessons Available")</div>
                            <div style="font-size:13px;opacity:0.75;">Lesson video preview</div>
                        </div>
                    </div>
                    <div class="card">
                        <div style="display:flex;flex-direction:column;gap:0;">
                            @{int counter = 0;}
                            @foreach (var lesson in Model.Lessons)
                            {
                                    counter += 1;
                                    <div class="lesson-row" onclick="playLesson(this)" data-video="@lesson.Video_Url" style="display:flex;align-items:center;gap:16px;padding:16px 0;cursor:pointer;border-bottom:1px solid var(--border-light);">
                                    <div style="width:36px;height:36px;border-radius:50%;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;">@counter</div>
                                    <div style="flex:1;">
                                        <div style="font-weight:600;">@lesson.Name</div>
                                        
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div id="quizzes" class="tab-content" style="display:none;">
                    <div class="page-header">
                        <h3 style="font-size:18px;font-weight:600;">Quizzes</h3>
                    </div>
                    <div class="card">
                        <div style="display:flex;flex-direction:column;gap:0;">
                            @if (Model.Quizzes != null && Model.Quizzes.Any())
                            {
                                @foreach (var quiz in Model.Quizzes)
                                {
                                    <div style="display:flex;align-items:center;gap:16px;padding:16px 0;border-bottom:1px solid var(--border-light);">
                                        @if (quiz.Status == "Completed")
                                        {
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                                        }
                                        else
                                        {
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 8v4l3 3" /></svg>
                                        }
                                        <div style="flex:1;">
                                            <div style="font-weight:600;">@quiz.Name</div>
                                            <div style="font-size:13px;color:var(--text-muted);">@quiz.QuestionCount questions &middot; Score: @quiz.score</div>
                                        </div>

                                        @if (quiz.Status == "Completed")
                                        {
                                            <span class="badge badge-success">Completed</span>
                                        }
                                        else if (quiz.Status == "In Progress")
                                        {
                                            <span class="badge badge-warning">In Progress</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-ghost">Not Started</span>
                                        }

                                        @if (quiz.Status != "Completed")
                                        {
                                            <a asp-controller="Student" asp-action="Take_Quiz" asp-route-id="@quiz.Id" class="btn btn-sm btn-primary">Take Quiz</a>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <p style="padding: 16px; color: var(--text-muted);">No quizzes available for this course.</p>
                            }
                        </div>
                    </div>
                </div>

                <div id="assessments" class="tab-content" style="display:none;">
                    <div class="page-header">
                        <h3 style="font-size:18px;font-weight:600;">Assessments</h3>
                    </div>
                    <div class="card">
                        <div style="display:flex;flex-direction:column;gap:0;">
                            @if (Model.Assessments != null && Model.Assessments.Any())
                            {
                                @foreach (var item in Model.Assessments)
                                {
                                    <div style="display:flex;align-items:center;gap:16px;padding:16px 0;border-bottom:1px solid var(--border-light);">
                                        <div style="width:20px;height:20px;border-radius:50%;border:2px solid @(item.Status == "Submitted" ? "#10B981" : "var(--primary)");display:flex;align-items:center;justify-content:center;">
                                            <div style="width:8px;height:8px;background:@(item.Status == "Submitted" ? "#10B981" : "var(--primary)");border-radius:50%;"></div>
                                        </div>
                                        <div style="flex:1;">
                                            <div style="font-weight:600;">@item.Name</div>
                                            <div style="font-size:13px;color:var(--text-muted);">Due: @item.DueDate &middot; Score: @item.score</div>
                                        </div>

                                        @if (item.Status == "Submitted")
                                        {
                                            <span class="badge badge-success">Submitted</span>
                                        }
                                        else if (item.Status == "Incomplete / Draft")
                                        {
                                            <span class="badge badge-warning">Draft</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-primary">Not Submitted</span>
                                        }

                                        @if (item.Status != "Submitted")
                                        {
                                            <a asp-controller="Student" asp-action="Submit_Assessment" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Open</a>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <p style="padding: 16px; color: var(--text-muted);">No assignments available.</p>
                            }
                        </div>
                    </div>
                </div>

                <div id="materials" class="tab-content" style="display:none;">
                    <div class="page-header">
                        <h3 style="font-size:18px;font-weight:600;">Course Materials</h3>
                    </div>
                    <div class="card">
                        <div style="display:flex;flex-direction:column;gap:0;">
                            @{
                                int materialCount = 0;
                            }
                            @foreach (var lesson in Model.Lessons)
                            {
                                if (lesson.Materials != null && lesson.Materials.Any())
                                {
                                    foreach (var material in lesson.Materials)
                                    {
                                        materialCount++;
                                        <div style="display:flex;align-items:center;gap:16px;padding:16px 0;border-bottom:1px solid var(--border-light);">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                                            <div style="flex:1;">
                                                <div style="font-weight:600;">@material.FileName</div>
                                                <div style="font-size:13px;color:var(--text-muted);">Lesson: @lesson.Name &middot; Size: @material.FileSize &middot;</div>
                                            </div>
                                            <a href="@material.DownloadUrl" class="btn btn-sm btn-ghost" download>Download</a>
                                        </div>
                                    }
                                }
                            }
                            @if (materialCount == 0)
                            {
                                <p style="padding: 16px; color: var(--text-muted);">No material files uploaded yet for any lesson.</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
            function switchTab(btn, tabId) {
                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                btn.classList.add('active');
                document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
                document.getElementById(tabId).style.display = 'block';
            }
            function playLesson(row) {
                if (!row.closest('#lessons')) return;
                const title = row.querySelector('div[style*="font-weight:600"]');
                const videoTitle = document.querySelector('.student-video-title');
                if (title && videoTitle) videoTitle.textContent = title.textContent;
            }
    </script>
    <script src="~/js/app.js"></script>
</body>
</html>