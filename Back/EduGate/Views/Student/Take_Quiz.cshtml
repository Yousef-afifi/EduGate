<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Take Quiz - EduGate</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar">
            <div class="sidebar-header"><a asp-controller="Home" asp-action="Index" class="logo"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>EduGate</a></div>
            <div class="sidebar-user"><div class="user-avatar" style="background:#3B82F6;">SJ</div><div class="user-info"><div class="user-name">Sarah Johnson</div><div class="user-role">Student</div></div></div>
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Main</div>
                    <a asp-controller="Student" asp-action="Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>Dashboard</a>
                    <a asp-controller="Student" asp-action="Courses" class="nav-item active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>My Courses</a>
                    <a asp-controller="Student" asp-action="Exams" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>Exams</a>
                    <a asp-controller="Student" asp-action="Schedule" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>Schedule</a>
                </div>
                <div class="nav-section"><div class="nav-section-title">Account</div><a asp-controller="Student" asp-action="Settings" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" /></svg>Settings</a></div>
            </nav>
            <div class="sidebar-footer"><a asp-controller="Auth" asp-action="Login" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Logout</a></div>
        </aside>

        <main class="main-content">
            <div class="topbar">
                <div style="display:flex;align-items:center;gap:12px;">
                    <a id="backLink" asp-controller="Student" asp-action="Courses" class="icon-btn"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" /></svg></a>
                    <h1 class="topbar-title" id="pageTitle">Take Quiz</h1>
                </div>
            </div>
            <div class="page-content">
                <div class="card" style="margin-bottom:24px;">
                    <div style="display:flex;justify-content:space-between;gap:16px;align-items:center;">
                        <div><h3 id="quizTitle" style="font-size:18px;font-weight:600;margin-bottom:4px;">Course Quiz</h3><p style="font-size:13px;color:var(--text-muted);">3 questions &middot; 20 minutes &middot; Passing score 60%</p></div>
                        <span class="badge badge-info">Available</span>
                    </div>
                </div>
                <div id="quizForm" style="display:flex;flex-direction:column;gap:16px;"></div>
                <div style="display:flex;justify-content:flex-end;margin-top:20px;">
                    <button class="btn btn-primary" onclick="submitQuiz()">Submit Quiz</button>
                </div>
            </div>
        </main>
    </div>
    <script src="~/js/app.js"></script>
    <script>
        const courses = { 1: 'Calculus II', 2: 'Physics 101', 3: 'Organic Chemistry', 4: 'Linear Algebra' };
        const courseId = new URLSearchParams(location.search).get('course') || '1';
        const courseName = courses[courseId] || courses[1];
        document.title = `${courseName} Quiz - EduGate`;
        document.getElementById('pageTitle').textContent = `${courseName} Quiz`;
        document.getElementById('quizTitle').textContent = `${courseName} Practice Quiz`;
        document.getElementById('backLink').href = `courses/${courseId}.html`;

        const questions = [
        { text: `Which concept is central to ${courseName}?`, options: ['Core definitions', 'Random guessing', 'Unrelated history', 'None of the above'] },
        { text: 'How many attempts are allowed for this practice quiz?', options: ['1 attempt', '2 attempts', 'Unlimited practice attempts', 'No attempts'] },
        { text: 'What should you do before submitting?', options: ['Review every answer', 'Close the page', 'Leave blanks', 'Skip instructions'] }
        ];
        document.getElementById('quizForm').innerHTML = questions.map((q, index) => `
        <div class="card">
        <div class="form-group">
        <label class="form-label">Question ${index + 1}</label>
        <p style="margin-bottom:12px;">${q.text}</p>
        ${q.options.map((option, optionIndex) => `
        <label style="display:flex;align-items:center;gap:10px;padding:10px 0;cursor:pointer;">
        <input type="radio" name="q${index}" value="${optionIndex}" style="accent-color:var(--primary);">
        <span>${option}</span>
        </label>
        `).join('')}
        </div>
        </div>
        `).join('');

        function submitQuiz() {
        showToast('Quiz submitted! Score: 86%', 'success');
        setTimeout(() => window.location.href = `courses/${courseId}.html`, 900);
        }
    </script>
</body>