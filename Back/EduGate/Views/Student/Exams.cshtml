<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        Exams - EduPlatform
    </title>
    <link rel="stylesheet" href="../../css/student-exams.css" />
</head>
<body data-user-name="@Model?.CurrentUserName" data-user-role="Student">
    @*
    Required ViewModel Data:
    * Available Exams
    * Student Exam Results
    * Upcoming Exam Count
    *@
    <div id="sidebar-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:99">
    </div>
    <div class="app-shell">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar__logo">
                <div class="sidebar__logo-mark">
                    &#127891;
                </div>
                <span class="sidebar__logo-name">
                    EduPlatform
                </span>
            </div>
            <div class="sidebar__user">
                <div class="sidebar__avatar" id="sidebar-avatar">
                    U
                </div>
                <div>
                    <div class="sidebar__user-name" id="sidebar-user-name">
                        @Model?.CurrentUserName
                    </div>
                    <div class="sidebar__user-role" id="sidebar-user-role">
                        Student
                    </div>
                </div>
            </div>
            <nav class="sidebar__nav" id="sidebar-nav">
                <div class="sidebar__nav-section">
                    Workspace
                </div>
                <a asp-controller="Student" asp-action="Dashboard" class="nav-item">
                    <span class="nav-icon">
                        &#127968;
                    </span>
                    <span>
                        Dashboard
                    </span>
                </a>
                <a asp-controller="Student" asp-action="Courses" class="nav-item">
                    <span class="nav-icon">
                        &#128218;
                    </span>
                    <span>
                        Courses
                    </span>
                </a>
                <a asp-controller="Student" asp-action="Exams" class="nav-item">
                    <span class="nav-icon">
                        &#128221;
                    </span>
                    <span>
                        Exams
                    </span>
                </a>
                <a asp-controller="Student" asp-action="Schedule" class="nav-item">
                    <span class="nav-icon">
                        &#128197;
                    </span>
                    <span>
                        Schedule
                    </span>
                </a>
                <a asp-controller="Student" asp-action="Settings" class="nav-item">
                    <span class="nav-icon">
                        &#9881;
                    </span>
                    <span>
                        Settings
                    </span>
                </a>
            </nav>
            <div class="sidebar__bottom">
                <button class="sidebar__logout" id="logout-btn">
                    <span class="nav-icon">
                        &#128682;
                    </span>
                    Sign Out
                </button>
            </div>
        </aside>
        <div class="main-content">
            <header class="topbar">
                <div class="topbar__left">
                    <button class="menu-toggle" id="menu-toggle">
                        &#9776;
                    </button>
                    <button class="sidebar-peek-toggle" id="sidebar-peek-toggle" title="Toggle sidebar">
                        &#9776;
                    </button>
                    <div>
                        <div class="topbar__title" id="page-title">
                            Exams
                        </div>
                        <div class="topbar__breadcrumb" id="page-breadcrumb">
                        </div>
                    </div>
                </div>
                <div class="topbar__right">
                    <div style="font-size:13px;font-weight:600;color:var(--navy)" id="topbar-user-name">
                        @Model?.CurrentUserName
                    </div>
                </div>
            </header>
            <main class="page-body">
                <div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between">
                    <div>
                        <h1 id="exams-heading">
                            Exams
                        </h1>
                        <p id="exams-subheading">
                            Review assigned exams and results
                        </p>
                    </div>
                </div>
                @* TODO: Backend
          Required Data:
          * Total Exams
          * Pending Exams
          * Completed Exams
          * Average Score or Submission Rate
          *@
                <div class="stats-row" id="exam-stats">
                    <div class="stat-card">
                        <div class="stat-card__icon">
                            &#128221;
                        </div>
                        <div class="stat-card__num">
                            0
                        </div>
                        <div class="stat-card__label">
                            Total Exams
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-card__icon">
                            &#9203;
                        </div>
                        <div class="stat-card__num">
                            0
                        </div>
                        <div class="stat-card__label">
                            Pending
                        </div>
                    </div>
                </div>
                <div class="filter-bar" style="margin-bottom:24px">
                    <button class="filter-pill active" data-status="all">
                        All Exams
                    </button>
                    <button class="filter-pill" data-status="pending">
                        Pending
                    </button>
                    <button class="filter-pill" data-status="completed">
                        Completed
                    </button>
                    <button class="filter-pill" data-status="missed">
                        Missed
                    </button>
                </div>
                <div class="exams-grid" id="exams-grid">
                    @* TODO: Backend
            Required Data:
            * Exam Id
            * Exam Title
            * Course Name
            * Duration Minutes
            * Question Count
            * Due Date
            * Exam Status
            * Student Score or Submission Count
            *@
                    <div class="exam-card" data-status="pending">
                        <div class="exam-card__icon">
                            &#128221;
                        </div>
                        <div class="exam-card__title">
                            Exam Title
                        </div>
                        <div class="exam-card__course">
                            Course Name
                        </div>
                        <div class="exam-card__details">
                            <div class="exam-detail-row">
                                &#127909; Duration:
                                <strong>
                                    Duration min
                                </strong>
                            </div>
                            <div class="exam-detail-row">
                                &#10067; Questions:
                                <strong>
                                    Question count
                                </strong>
                            </div>
                            <div class="exam-detail-row">
                                &#128197; Due:
                                <strong>
                                    Due date
                                </strong>
                            </div>
                        </div>
                        <div class="exam-card__footer">
                            <span class="badge badge-amber">
                                Status
                            </span>
                            <a class="btn-amber" href="/Student/TakeExam?id=@Model?.ExamId">
                                Open
                            </a>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
    <script src="../../js/app.js">
    </script>
</body>