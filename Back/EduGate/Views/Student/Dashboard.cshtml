<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard - EduGate</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar">
            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                    EduGate
                </a>
            </div>
            <div class="sidebar-user">
                <div class="user-avatar" style="background:#3B82F6;">SJ</div>
                <div class="user-info"><div class="user-name">Sarah Johnson</div><div class="user-role">Student</div></div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Main</div>
                    <a asp-controller="Student" asp-action="Dashboard" class="nav-item active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>Dashboard</a>
                    <a asp-controller="Student" asp-action="Courses" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>My Courses</a>
                    <a asp-controller="Student" asp-action="Exams" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>Exams</a>
                    <a asp-controller="Student" asp-action="Schedule" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>Schedule</a>
                </div>
                <div class="nav-section">
                    <div class="nav-section-title">Account</div>
                    <a asp-controller="Student" asp-action="Settings" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" /></svg>Settings</a>
                </div>
            </nav>
            <div class="sidebar-footer">
                <a asp-controller="Auth" asp-action="Login" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Logout</a>
            </div>
        </aside>

        <main class="main-content">
            <div class="topbar">
                <h1 class="topbar-title">Dashboard</h1>
                <div class="topbar-actions">
                    <button class="icon-btn" onclick="showToast('No new notifications', 'info')"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 01-3.46 0" /></svg><span style="position:absolute;top:4px;right:4px;width:8px;height:8px;background:var(--primary);border-radius:50%;"></span></button>
                </div>
            </div>

            <div class="page-content">
                <!-- Welcome Banner -->
                <div class="card" style="background:linear-gradient(135deg,#3B82F6,#60A5FA);color:white;margin-bottom:32px;">
                    <h2 style="font-size:22px;font-weight:700;margin-bottom:8px;">Welcome back, Sarah!</h2>
                    <p style="opacity:0.9;font-size:14px;">You have 2 upcoming exams this week. Keep up the great work!</p>
                </div>

                <!-- Stats -->
                <div class="stats-grid" style="grid-template-columns:repeat(4,1fr);">
                    <div class="stat-card">
                        <div class="stat-header"><span class="stat-label">Enrolled Courses</span><div class="stat-icon blue"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg></div></div>
                        <div class="stat-value">5</div>
                        <div class="stat-change up">Active</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-header"><span class="stat-label">Avg. Score</span><div class="stat-icon green"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /></svg></div></div>
                        <div class="stat-value">84%</div>
                        <div class="stat-change up">+3% this month</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-header"><span class="stat-label">Completed</span><div class="stat-icon purple"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div></div>
                        <div class="stat-value">24</div>
                        <div class="stat-change up">Lessons done</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-header"><span class="stat-label">Upcoming</span><div class="stat-icon red"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg></div></div>
                        <div class="stat-value">2</div>
                        <div class="stat-change down">Exams this week</div>
                    </div>
                </div>

                <div class="dashboard-grid">
                    <div>
                        <div class="card">
                            <div class="card-header"><h3 class="card-title">My Courses</h3><a asp-controller="Student" asp-action="Courses" style="font-size:13px;color:var(--primary);font-weight:500;">View All</a></div>
                            <div style="display:flex;flex-direction:column;gap:16px;">
                                <div>
                                    <div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span style="font-size:14px;font-weight:500;">Calculus II</span></div>
                                </div>
                                <div>
                                        <div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span style="font-size:14px;font-weight:500;">Physics 101</span></div>

                                    
                                </div>
                                <div>
                                    <div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span style="font-size:14px;font-weight:500;">Organic Chemistry</span></div>
                                    
                                </div>
                                <div>
                                    <div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span style="font-size:14px;font-weight:500;">Linear Algebra</span></div>
                                    
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-header"><h3 class="card-title">Recent Grades</h3></div>
                            <div class="table-wrap">
                                <table class="data-table">
                                    <thead><tr><th>Assessment</th><th>Course</th><th>Score</th></tr></thead>
                                    <tbody>
                                        <tr><td>Quiz 3</td><td>Calculus II</td><td>92%</td></tr>
                                        <tr><td>Lab Report</td><td>Physics 101</td><td>85%</td></tr>
                                        <tr><td>Unit Test 2</td><td>Organic Chemistry</td><td>96%</td></tr>
                                        <tr><td>Problem Set 4</td><td>Linear Algebra</td><td>78%</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div>
                        

                        <div class="card">
                            <div class="card-header"><h3 class="card-title">This Week's Schedule</h3></div>
                            <div style="display:flex;flex-direction:column;gap:10px;">
                                <div style="display:flex;align-items:center;gap:10px;font-size:14px;">
                                    <span style="width:70px;color:var(--text-muted);font-size:12px;">Mon</span>
                                    <span style="flex:1;">Calculus II - Integration</span>
                                    <span style="color:var(--text-muted);font-size:12px;">10:00 AM</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;font-size:14px;">
                                    <span style="width:70px;color:var(--text-muted);font-size:12px;">Tue</span>
                                    <span style="flex:1;">Physics 101 - Lab</span>
                                    <span style="color:var(--text-muted);font-size:12px;">2:00 PM</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;font-size:14px;">
                                    <span style="width:70px;color:var(--text-muted);font-size:12px;">Wed</span>
                                    <span style="flex:1;">Organic Chemistry - Lecture</span>
                                    <span style="color:var(--text-muted);font-size:12px;">9:00 AM</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;font-size:14px;">
                                    <span style="width:70px;color:var(--text-muted);font-size:12px;">Thu</span>
                                    <span style="flex:1;">Linear Algebra - Tutorial</span>
                                    <span style="color:var(--text-muted);font-size:12px;">11:00 AM</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
    <script src="~/js/app.js"></script>
</body>