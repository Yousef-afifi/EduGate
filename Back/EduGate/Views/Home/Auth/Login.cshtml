<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Teacher & Student Login - EduPlatform</title>
    <link rel="stylesheet" href="~/css/auth-login.css" />
</head>
<body>
    <header class="auth-header" aria-label="Authentication"></header>
    <main class="auth-main">
        <div class="auth-root">
            <div class="auth-brand">
                <div class="auth-brand__logo">
                    <div class="auth-brand__logo-mark">&#127891;</div>
                    <span class="auth-brand__logo-name">EduPlatform</span>
                </div>

                <h1 class="auth-brand__headline">
                    Launch Your Teaching<br>Platform <span>Faster.</span>
                </h1>
                <p class="auth-brand__sub">
                    One ready platform for online teachers. Upload lectures, create exams and assignments,
                    generate student accounts, and keep every class organized from one dashboard.
                </p>

                <div class="auth-brand__stats">
                    <div>
                        <div class="auth-brand__stat-num">200+</div>
                        <div class="auth-brand__stat-lbl">Starter seats</div>
                    </div>
                    <div>
                        <div class="auth-brand__stat-num">600</div>
                        <div class="auth-brand__stat-lbl">Growth package</div>
                    </div>
                    <div>
                        <div class="auth-brand__stat-num">1000</div>
                        <div class="auth-brand__stat-lbl">Scale package</div>
                    </div>
                </div>

                <div class="auth-brand__deco"></div>
                <div class="auth-brand__deco2"></div>
            </div>

            <div class="auth-form-panel">
                <div class="auth-form-box">
                    <h2>Welcome back</h2>
                    <p class="auth-sub">Don't have an account? <a href="/Auth/Register">Create one</a></p>

                    <div class="alert alert-error" id="login-alert" role="alert">
                        <span>&#9888;</span>
                        <span class="alert-msg"></span>
                    </div>

                    <form id="login-form" action="/Auth/Login" method="post" novalidate>
                        <div class="form-group">
                            <label for="email">Email Address</label>
                            <input type="email" id="email" name="Email" placeholder="you@example.com" autocomplete="email" />
                            <div class="field-error"></div>
                        </div>

                        <div class="form-group">
                            <label for="password">Password</label>
                            <input type="password" id="password" name="Password" placeholder="Your password" autocomplete="current-password" />
                            <div class="field-error"></div>
                        </div>

                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
                            <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--gray-600);cursor:pointer">
                                <input type="checkbox" id="remember-me" name="RememberMe" value="true" style="accent-color:var(--amber);width:14px;height:14px" />
                                Remember me
                            </label>
                            <a href="#" style="font-size:13px;color:var(--amber-dark);font-weight:500">Need help?</a>
                        </div>

                        <button type="submit" class="btn-primary" id="login-btn">Sign In</button>
                    </form>

                    <!-- MVC required: AuthController.Login POST validates credentials and creates the cookie/session. -->
                </div>
            </div>
        </div>
    </main>

    <script src="~/js/auth-login.js"></script>
</body>