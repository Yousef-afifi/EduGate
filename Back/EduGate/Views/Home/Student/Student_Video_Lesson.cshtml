<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        Lesson - EduPlatform
    </title>
    <link rel="stylesheet" href="../../css/student-video-lesson.css" />
</head>
<body data-user-name="@Model?.CurrentUserName" data-user-role="Student">
    @*
    Required ViewModel Data:
    * Course Id
    * Course Name
    * Lesson Id
    * Lesson Title
    * Lesson Type
    * Lesson Duration
    * Video Url
    * Lesson Description
    * Previous Lesson Id
    * Next Lesson Id
    *@
    <div id="sidebar-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:99">
    </div>
    <div class="app-shell">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar__logo">
                <div class="sidebar__logo-mark">
                    &#127891;
                </div>
                <span class="sidebar__logo-name">
                    EduPlatform
                </span>
            </div>
            <div class="sidebar__user">
                <div class="sidebar__avatar" id="sidebar-avatar">
                    U
                </div>
                <div>
                    <div class="sidebar__user-name" id="sidebar-user-name">
                        @Model?.CurrentUserName
                    </div>
                    <div class="sidebar__user-role" id="sidebar-user-role">
                        Student
                    </div>
                </div>
            </div>
            <nav class="sidebar__nav" id="sidebar-nav">
                <div class="sidebar__nav-section">
                    Workspace
                </div>
                <a href="/Student/Dashboard" class="nav-item">
                    <span class="nav-icon">
                        &#127968;
                    </span>
                    <span>
                        Dashboard
                    </span>
                </a>
                <a href="/Student/Courses" class="nav-item">
                    <span class="nav-icon">
                        &#128218;
                    </span>
                    <span>
                        My Courses
                    </span>
                </a>
                <a href="/Student/Exams" class="nav-item">
                    <span class="nav-icon">
                        &#128221;
                    </span>
                    <span>
                        My Exams
                    </span>
                </a>
                <a href="/Student/Dashboard?view=schedule" class="nav-item">
                    <span class="nav-icon">
                        &#128197;
                    </span>
                    <span>
                        Schedule
                    </span>
                </a>
                <a href="/Student/Dashboard?view=settings" class="nav-item">
                    <span class="nav-icon">
                        &#9881;
                    </span>
                    <span>
                        Settings
                    </span>
                </a>
            </nav>
            <div class="sidebar__bottom">
                <button class="sidebar__logout" id="logout-btn">
                    <span class="nav-icon">
                        &#128682;
                    </span>
                    Sign Out
                </button>
            </div>
        </aside>
        <div class="main-content">
            <header class="topbar">
                <div class="topbar__left">
                    <button class="menu-toggle" id="menu-toggle">
                        &#9776;
                    </button>
                    <button class="sidebar-peek-toggle" id="sidebar-peek-toggle" title="Toggle sidebar">
                        &#9776;
                    </button>
                    <div>
                        <div class="topbar__title" id="page-title">
                            Video Lesson
                        </div>
                        <div class="topbar__breadcrumb" id="page-breadcrumb">
                        </div>
                    </div>
                </div>
                <div class="topbar__right">
                    <div style="font-size:13px;font-weight:600;color:var(--navy)" id="topbar-user-name">
                        @Model?.CurrentUserName
                    </div>
                </div>
            </header>
            <main class="page-body" id="lesson-content">
                <div class="lesson-layout">
                    <section class="video-panel">
                        @* TODO: Backend
              Required Data:
              * Lesson Video Url
              * Lesson Title
              * Course Name
              *@
                        <div id="video-player-wrap" style="background:var(--navy);border-radius:var(--radius);min-height:360px;display:flex;align-items:center;justify-content:center;color:var(--white)">
                            Video player placeholder
                        </div>
                        <h1>
                            Lesson Title
                        </h1>
                        <p>
                            Lesson description placeholder rendered by Razor.
                        </p>
                        <form action="/Student/Lessons/Complete" method="post">
                            <input type="hidden" name="LessonId" value="@Model?.LessonId" />
                            <button class="btn-amber" id="mark-done-btn" type="submit">
                                Mark Complete
                            </button>
                        </form>
                    </section>
                    <aside class="lessons-sidebar">
                        <div class="lessons-sidebar-header">
                            <strong>
                                Course Lessons
                            </strong>
                        </div>
                        @* TODO: Backend
              Required Data:
              * Lesson List
              * Active Lesson Id
              * Completed/Locked Status
              *@
                        <div class="lessons-sidebar-list">
                            <a class="lesson-row active" href="#">
                                Lesson Title
                            </a>
                        </div>
                    </aside>
                </div>
            </main>
        </div>
    </div>
    <script src="../../js/app.js">
    </script>
</body>