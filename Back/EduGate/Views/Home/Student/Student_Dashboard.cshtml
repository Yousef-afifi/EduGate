<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        Dashboard - EduPlatform
    </title>
    <link rel="stylesheet" href="../../css/student-dashboard.css" />
</head>
<body data-user-name="@Model?.CurrentUserName" data-user-role="Student">
    @*
    Required ViewModel Data:
    * Student Name
    * Completed Courses
    * In Progress Courses
    * Total Exams
    * Average Score
    * Continue Watching Courses
    * Upcoming Exams
    *@
    <div id="sidebar-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:99">
    </div>
    <div class="app-shell">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar__logo">
                <div class="sidebar__logo-mark">
                    &#127891;
                </div>
                <span class="sidebar__logo-name">
                    EduPlatform
                </span>
            </div>
            <div class="sidebar__user">
                <div class="sidebar__avatar" id="sidebar-avatar">
                    U
                </div>
                <div>
                    <div class="sidebar__user-name" id="sidebar-user-name">
                        @Model?.CurrentUserName
                    </div>
                    <div class="sidebar__user-role" id="sidebar-user-role">
                        Student
                    </div>
                </div>
            </div>
            <nav class="sidebar__nav" id="sidebar-nav">
                <div class="sidebar__nav-section">
                    Workspace
                </div>
                <a href="/Student/Dashboard" class="nav-item">
                    <span class="nav-icon">
                        &#127968;
                    </span>
                    <span>
                        Dashboard
                    </span>
                </a>
                <a href="/Student/Courses" class="nav-item">
                    <span class="nav-icon">
                        &#128218;
                    </span>
                    <span>
                        My Courses
                    </span>
                </a>
                <a href="/Student/Exams" class="nav-item">
                    <span class="nav-icon">
                        &#128221;
                    </span>
                    <span>
                        My Exams
                    </span>
                </a>
                <a href="/Student/Dashboard?view=schedule" class="nav-item">
                    <span class="nav-icon">
                        &#128197;
                    </span>
                    <span>
                        Schedule
                    </span>
                </a>
                <a href="/Student/Dashboard?view=settings" class="nav-item">
                    <span class="nav-icon">
                        &#9881;
                    </span>
                    <span>
                        Settings
                    </span>
                </a>
            </nav>
            <div class="sidebar__bottom">
                <button class="sidebar__logout" id="logout-btn">
                    <span class="nav-icon">
                        &#128682;
                    </span>
                    Sign Out
                </button>
            </div>
        </aside>
        <div class="main-content">
            <header class="topbar">
                <div class="topbar__left">
                    <button class="menu-toggle" id="menu-toggle">
                        &#9776;
                    </button>
                    <button class="sidebar-peek-toggle" id="sidebar-peek-toggle" title="Toggle sidebar">
                        &#9776;
                    </button>
                    <div>
                        <div class="topbar__title" id="page-title">
                            Dashboard
                        </div>
                        <div class="topbar__breadcrumb" id="page-breadcrumb">
                        </div>
                    </div>
                </div>
                <div class="topbar__right">
                    <div class="topbar-search">
                        <span class="search-icon">
                            &#128269;
                        </span>
                        <input type="text" placeholder="Search lessons, students, exams..." id="global-search" />
                    </div>
                    <div style="font-size:13px;font-weight:600;color:var(--navy)" id="topbar-user-name">
                        @Model?.CurrentUserName
                    </div>
                </div>
            </header>
            <main class="page-body" id="dashboard-content">
                <div class="page-header">
                    <h1>
                        Student Dashboard
                    </h1>
                    <p>
                        My learning space
                    </p>
                </div>
                @* TODO: Backend
          Required Data:
          * Completed Courses
          * Courses In Progress
          * Exams Tracked
          * Average Score
          *@
                <div class="stats-row">
                    <div class="stat-card">
                        <div class="stat-card__icon">
                            &#128101;
                        </div>
                        <div class="stat-card__num">
                            0
                        </div>
                        <div class="stat-card__label">
                            Completed Courses
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-card__icon">
                            &#128218;
                        </div>
                        <div class="stat-card__num">
                            0
                        </div>
                        <div class="stat-card__label">
                            Active Courses
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-card__icon">
                            &#128221;
                        </div>
                        <div class="stat-card__num">
                            0
                        </div>
                        <div class="stat-card__label">
                            Exams
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-card__icon">
                            &#127942;
                        </div>
                        <div class="stat-card__num">
                            0%
                        </div>
                        <div class="stat-card__label">
                            Average Score
                        </div>
                    </div>
                </div>
                <div class="section-header">
                    <div>
                        <div class="section-title">
                            Continue Watching
                        </div>
                        <div style="font-size:13px;color:var(--gray-400);margin-top:6px">
                            Razor will render real records here.
                        </div>
                    </div>
                    <a href="/Student/Courses" class="section-link">
                        Open all courses
                    </a>
                </div>
                <div class="cards-grid">
                    @* TODO: Backend
            Required Data:
            * Course Id
            * Course Name
            * Course Description
            * Course Category
            * Teacher Name
            * Lesson Count
            * Duration
            * Level
            * Progress Percentage
            * Student Count
            *@
                    <div class="course-card" data-category="Programming" onclick="window.location.href='/Student/CourseDetails?id=@Model?.CourseId'">
                        <div class="course-card__thumb">
                            <span style="position:relative;z-index:1">
                                &#128218;
                            </span>
                            <span class="course-card__thumb-label">
                                Template
                            </span>
                        </div>
                        <div class="course-card__body">
                            <div class="course-card__category">
                                Course Category
                            </div>
                            <div class="course-card__title">
                                Course Name
                            </div>
                            <div class="course-card__meta">
                                <span>
                                    &#128196; Lesson count
                                </span>
                                <span>
                                    &#127909; Duration
                                </span>
                            </div>
                            <div class="course-card__progress-bar">
                                <div class="course-card__progress-fill" style="width:0%">
                                </div>
                            </div>
                            <div class="course-card__progress-label">
                                <span>
                                    Progress
                                </span>
                                <span>
                                    0%
                                </span>
                            </div>
                        </div>
                        <div class="course-card__footer">
                            <div class="course-card__author">
                                <div class="course-card__avatar-sm">
                                    T
                                </div>
                                Teacher Name
                            </div>
                            <span class="badge badge-amber">
                                Level
                            </span>
                        </div>
                    </div>
                </div>
                <div class="section-header" style="margin-top:40px">
                    <div>
                        <div class="section-title">
                            Upcoming Exams
                        </div>
                        <div style="font-size:13px;color:var(--gray-400);margin-top:6px">
                            Razor will render real exam records here.
                        </div>
                    </div>
                    <a href="/Student/Exams" class="section-link">
                        See exam page
                    </a>
                </div>
                <div class="exams-grid" style="grid-template-columns:repeat(auto-fill,minmax(260px,1fr))">
                    @* TODO: Backend
            Required Data:
            * Exam Id
            * Exam Title
            * Course Name
            * Duration Minutes
            * Question Count
            * Due Date
            * Exam Status
            * Student Score or Submission Count
            *@
                    <div class="exam-card" data-status="pending">
                        <div class="exam-card__icon">
                            &#128221;
                        </div>
                        <div class="exam-card__title">
                            Exam Title
                        </div>
                        <div class="exam-card__course">
                            Course Name
                        </div>
                        <div class="exam-card__details">
                            <div class="exam-detail-row">
                                &#127909; Duration:
                                <strong>
                                    Duration min
                                </strong>
                            </div>
                            <div class="exam-detail-row">
                                &#10067; Questions:
                                <strong>
                                    Question count
                                </strong>
                            </div>
                            <div class="exam-detail-row">
                                &#128197; Due:
                                <strong>
                                    Due date
                                </strong>
                            </div>
                        </div>
                        <div class="exam-card__footer">
                            <span class="badge badge-amber">
                                Status
                            </span>
                            <a class="btn-amber" href="/Student/TakeExam?id=@Model?.ExamId">
                                Open
                            </a>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
    <script src="../../js/app.js">
    </script>
</body>